<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- ── Header Banner Card ────────────────────────────────────── -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="281dp"
            android:background="@drawable/bg_header"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="36dp"
            android:paddingEnd="24dp"
            android:paddingBottom="32dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_title"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="16dp"
                android:text="@string/subtitle"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />

            <!-- Thermometer image -->
            <ImageView
                android:id="@+id/ivThermometer"
                android:layout_width="280dp"
                android:layout_height="131dp"
                android:contentDescription="@string/thermometer_desc"
                android:src="@drawable/ic_thermometer" />

        </LinearLayout>

        <!-- ── Input Card ────────────────────────────────────────────── -->

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:strokeWidth="0dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/enter_temperature"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="12dp" />

                <EditText
                    android:id="@+id/etTemperature"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="@string/temperature_hint"
                    android:inputType="numberDecimal|numberSigned"
                    android:textSize="20sp"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:background="@drawable/bg_edittext"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:gravity="center_vertical"
                    android:maxLines="1"
                    android:imeOptions="actionDone"
                    android:importantForAutofill="no" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Conversion Direction Card ─────────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:strokeWidth="0dp"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/select_conversion"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="12dp" />

                <RadioGroup
                    android:id="@+id/rgConversion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/rbFtoC"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/f_to_c"
                        android:textSize="15sp"
                        android:textColor="@color/text_primary"
                        android:checked="true"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:buttonTint="@color/primary" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider"
                        android:layout_marginStart="8dp" />

                    <RadioButton
                        android:id="@+id/rbCtoF"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/c_to_f"
                        android:textSize="15sp"
                        android:textColor="@color/text_primary"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:buttonTint="@color/primary" />

                </RadioGroup>

                <!-- Bounds info -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/bounds_fahrenheit"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/bounds_celsius"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"
                        android:gravity="center" />

                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Convert Button ─────────────────────────────────────────── -->
        <Button
            android:id="@+id/btnConvert"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/convert"
            android:textSize="16sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FF0000"
            app:cornerRadius="10dp"
            android:layout_marginBottom="20dp" />

        <!-- ── Result Card ────────────────────────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/result_background"
            app:strokeColor="@color/primary_light"
            app:strokeWidth="1dp"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/result_label"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary"
                    android:textAllCaps="true"
                    android:letterSpacing="0.15"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvResult"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/result_placeholder"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:gravity="center" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
